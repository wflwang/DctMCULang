{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "DctNY",
    "scopeName": "source.DctNY",
    "fileTypes": [],
    "patterns": [
        {
            "name": "comment.line.pdk",
            "match": "(;|//).*$",
            "settings": { "foreground": "#008000" }
        },
        {
            "name": "entity.name.label.assembly",
            "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*):",
            "settings": { "foreground": "#FFCC00" }
        },
        {
            "name": "keyword.control.pseudo.pdk",
            "match": "(?i)\\b(ORG|END|EQU|DB|DW|MACRO|ENDM|CBLOCK|ENDC|ERROR)\\b",
            "settings": { "foreground": "#6699FF" }
        },
        {
            "name": "string.error.pdk",
            "match": "(?i)\\bERROR\\b\\s+(.*)$",
            "captures": {
                "1": { "settings": { "foreground": "#FF6699" } }
            }
        },
        {
            "name": "keyword.control.pseudo.pdk",
            "match": "#(?i)\\b(DEFINE|INCLUDE|IF|IFDEF|IFNDEF|ELIF|ELSE|ENDIF)\\b",
            "settings": { "foreground": "#6699FF" }
        },
        {
            "name": "keyword.control.pseudo.pdk",
            "match": "(?i)\\b(IF|IFDEF|IFNDEF|ELIF|ELSE|ENDIF)\\b",
            "settings": { "foreground": "#6699FF" }
        },
        {
            "name": "string.include.file.pdk",
            "match": "([\">])([^\">]+)\\1",
            "captures": {
                "1": { "settings": { "foreground": "#6699FF" } },
                "2": { "settings": { "foreground": "#FFFF99", "background": "#333300" } }
            }
        },
        {
            "name": "keyword.instruction.pdk",
            "match": "(?i)\\b(ANDAR|IORAR|XORAR|ANDIA|IORIA|XORIA|ADDAR|SUBAR|ADCAR|SBCAR|ADDIA|SUBIA|ADCIA|SBCIA|RRR|RLR|COMR|INCR|DECR|CLRA|CLRR|DAA|CMPAR|BTRSC|BTRSS|INCRSZ|DECRSZ|MOVAR|MOVR|MOVIA|IOST|IOSTR|SFUN|SFUNR|T0MD|T0MDR|NOP|SLEEP|CLRWDT|ENI|DISI|INT|RET|RETIE|RETIA|CALLA|GOTOA|LCALL|LGOTO|TABLEA|BSR|BCR|SWAPR)\\b",
            "settings": { "foreground": "#0066FF" }
        },
        {
            "name": "cblock.variable.pdk",
            "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b",
            "context": [
                {
                    "match": "\\bCBLOCK\\b",
                    "push": "cblock"
                },
                {
                    "context": "cblock",
                    "match": "\\bENDC\\b",
                    "pop": true
                }
            ],
            "settings": { "foreground": "#FFFFFF" }
        },



        {
            "name": "constant.numeric.pdk",
            "match": "\\b(0x[0-9A-Fa-f]+|\\d+)\\b",
            "settings": { "foreground": "#FF6600" }
        },
        {
            "name": "variable.register.pdk",
            "match": "(?i)\\b(a|pa|pb)\\b",
            "settings": { "foreground": "#9933CC" }
        }
    ]
}
