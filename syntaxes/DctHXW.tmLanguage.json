{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "DctHXW",
    "scopeName": "source.DctHXW",
    "fileTypes": [],
    "patterns": [
        {
            "name": "comment.line.pdk",
            "match": "(;|//).*$",
            "settings": { "foreground": "#008000" }
        },
        {
            "name": "entity.name.label.assembly",
            "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*):",
            "settings": { "foreground": "#FFCC00" }
        },
        {
            "name": "keyword.control.pseudo.pdk",
            "match": "(?i)\\b(ORG|END|EQU|DB|DW|MACRO|ENDM)\\b",
            "settings": { "foreground": "#6699FF" }
        },
        {
            "name": "keyword.control.pseudo.pdk",
            "match": "#(?i)\\b(DEFINE|INCLUDE|IF|IFDEF|IFNDEF|ELIF|ELSE|ENDIF)\\b",
            "settings": { "foreground": "#6699FF" }
        },
        {
            "name": "keyword.control.pseudo.pdk",
            "match": "(?i)\\b(IF|IFDEF|IFNDEF|ELIF|ELSE|ENDIF)\\b",
            "settings": { "foreground": "#6699FF" }
        },

        {
            "name": "keyword.instruction.hxw",
            "match": "(?i)\\b(BCR|BCF|BSR|BSF|BTRSC|BTFSC|BTRSS|BTFSS|NOP|CLRWDT|SLEEP|DAA|DAW|DAS|RETURN|RETFIE|CLRA|CLRW|CLRR|CLRF|MOVAR|MOVWF|MOVR|MOVF|MOVIA|MOVLW|DECR|DECF|DECRSZ|DECFSZ|INCR|INCF|INCRSZ|INCFSZ|ADDAR|ADDWF|ADCAR|ADCWF|SUBAR|SUBWF|SBCAR|SBCWF|ANDAR|ANDWF|ANDIA|ANDLW|IORAR|IORWF|IORIA|IORLW|XORAR|XORWF|XORIA|XORLW|COMR|COMF|RLR|RLF|RRR|RRF|SWAPR|SWAPF|ADDIA|ADDLW|SUBIA|SUBLW|RETIA|RETLW|CALL|GOTO)\\b",
            "settings": { "foreground": "#0066FF" }
        },
        {
            "name": "cblock.variable.pdk",
            "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b",
            "context": [
                {
                    "match": "\\bCBLOCK\\b",
                    "push": "cblock"
                },
                {
                    "context": "cblock",
                    "match": "\\bENDC\\b",
                    "pop": true
                }
            ],
            "settings": { "foreground": "#FFFFFF" }
        },


        {
            "name": "string.include.file.pdk",
            "match": "([\">])([^\">]+)\\1",
            "captures": {
                "1": { "settings": { "foreground": "#6699FF" } },
                "2": { "settings": { "foreground": "#FFFF99", "background": "#333300" } }
            }
        },
        {
            "name": "constant.numeric.pdk",
            "match": "\\b(0x[0-9A-Fa-f]+|\\d+)\\b",
            "settings": { "foreground": "#FF6600" }
        },
        {
            "name": "variable.register.pdk",
            "match": "(?i)\\b(a|pa|pb)\\b",
            "settings": { "foreground": "#9933CC" }
        }
    ]
}
